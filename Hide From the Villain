-- Teleport (đơn giản hóa)
local function toggleTeleportPower(state)
    for _, conn in ipairs(teleportConnections) do conn:Disconnect() end
    teleportConnections = {}
    if not state then return end

    table.insert(teleportConnections, UIS.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or isTeleporting then return end
        if not Config.Powers.powerTeleport then return end

        if input.KeyCode == keybinds.powerTeleport then
            local character = LocalPlayer.Character
            if not character or not character:FindFirstChild("HumanoidRootPart") then return end

            local mouse = LocalPlayer:GetMouse()
            local rootPart = character.HumanoidRootPart
            local targetPos = mouse.Hit.Position

            local distance = (targetPos - rootPart.Position).Magnitude
            if distance < 10 then return end

            rootPart.CFrame = CFrame.new(targetPos + Vector3.new(0, 3, 0))
        end
    end))
end

