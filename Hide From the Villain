-- ===== TELEPORT CRATE FUNCTION =====
local function teleportToCrate()
    if not LocalPlayer.Character then 
        print("❌ Không có nhân vật!")
        return 
    end
    
    local humanoidRootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not humanoidRootPart then 
        print("❌ Không tìm thấy HumanoidRootPart!")
        return 
    end
    
    -- Tìm tất cả crate trong workspace
    local crates = {}
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj.Name and string.lower(obj.Name):find("crate") then
            table.insert(crates, obj)
        elseif obj:IsA("Part") and obj.Name and string.lower(obj.Name):find("crate") then
            table.insert(crates, obj)
        elseif obj:IsA("BasePart") and obj.Parent and obj.Parent.Name and string.lower(obj.Parent.Name):find("crate") then
            table.insert(crates, obj)
        end
    end
    
    if #crates == 0 then
        -- Thử tìm theo tên khác
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("BasePart") and obj.Name and (
                string.lower(obj.Name):find("chest") or 
                string.lower(obj.Name):find("box") or
                string.lower(obj.Name):find("supply") or
                string.lower(obj.Name):find("loot")
            ) then
                table.insert(crates, obj)
            end
        end
    end
    
    if #crates == 0 then
        print("❌ Không tìm thấy crate nào trong game!")
        return
    end
    
    -- Tìm crate gần nhất
    local nearestCrate = nil
    local nearestDist = math.huge
    local playerPos = humanoidRootPart.Position
    
    for _, crate in ipairs(crates) do
        local cratePos
        if crate:IsA("BasePart") then
            cratePos = crate.Position
        elseif crate:IsA("Model") then
            local primary = crate.PrimaryPart or crate:FindFirstChildWhichIsA("BasePart")
            if primary then
                cratePos = primary.Position
            end
        end
        
        if cratePos then
            local dist = (cratePos - playerPos).Magnitude
            if dist < nearestDist then
                nearestDist = dist
                nearestCrate = crate
            end
        end
    end
    
    if not nearestCrate then
        print("❌ Không tìm thấy crate hợp lệ!")
        return
    end
    
    -- Lấy vị trí của crate
    local targetPos
    if nearestCrate:IsA("BasePart") then
        targetPos = nearestCrate.Position
    elseif nearestCrate:IsA("Model") then
        local primary = nearestCrate.PrimaryPart or nearestCrate:FindFirstChildWhichIsA("BasePart")
        if primary then
            targetPos = primary.Position
        end
    end
    
    if not targetPos then
        print("❌ Không thể xác định vị trí crate!")
        return
    end
    
    -- Teleport với animation
    local startPos = humanoidRootPart.Position
    local distance = (targetPos - startPos).Magnitude
    
    if distance < 5 then
        print("⚠️ Bạn đã ở gần crate!")
        return
    end
    
    print("🔄 Đang teleport đến crate...")
    
    -- Tạo hiệu ứng teleport
    local tweenInfo = TweenInfo.new(
        0.3,
        Enum.EasingStyle.Quad,
        Enum.EasingDirection.Out
    )
    
    -- Teleport lên cao 1 chút rồi xuống
    local midPos = Vector3.new(targetPos.X, targetPos.Y + 10, targetPos.Z)
    local tween1 = TweenService:Create(humanoidRootPart, tweenInfo, {CFrame = CFrame.new(midPos)})
    local tween2 = TweenService:Create(humanoidRootPart, tweenInfo, {CFrame = CFrame.new(targetPos)})
    
    tween1:Play()
    tween1.Completed:Connect(function()
        tween2:Play()
    end)
    
    print("✅ Đã teleport đến crate!")
    print("📦 Khoảng cách: " .. math.floor(distance) .. " units")
end

