local function isPlayerVillain(p)
    if p.Name == "Villain" then return true end
    if p.Team and (string.find(string.lower(p.Team.Name), "villain") or string.find(string.lower(p.Team.Name), "killer")) then return true end
    if p:GetAttribute("Role") == "Villain" or p:GetAttribute("IsVillain") == true then return true end
    return false
end

local playerRolesCache = {}
local function assignCachedRole(p)
    playerRolesCache[p] = isPlayerVillain(p)
end

