local characterPartsCache = {}
local function updateNoclipCache()
    table.clear(characterPartsCache)
    local char = LocalPlayer.Character
    if char then
        for _, part in ipairs(char:GetDescendants()) do
            if part:IsA("BasePart") then table.insert(characterPartsCache, part) end
        end
    end
end

local function hookNoclipCharacter(char)
    updateNoclipCache()
    table.insert(Connections, char.DescendantAdded:Connect(function(d)
        if d:IsA("BasePart") then table.insert(characterPartsCache, d) end
    end))
    table.insert(Connections, char.DescendantRemoving:Connect(function(d)
        local idx = table.find(characterPartsCache, d)
        if idx then table.remove(characterPartsCache, idx) end
    end))
end

if LocalPlayer.Character then hookNoclipCharacter(LocalPlayer.Character) end
table.insert(Connections, LocalPlayer.CharacterAdded:Connect(hookNoclipCharacter))

-- TP Tool
local tpToolInstance = nil
local function giveTpTool()
    local char = LocalPlayer.Character
    if not char then return end
    if char:FindFirstChild("TP Tool") or LocalPlayer.Backpack:FindFirstChild("TP Tool") then return end

    local tool = Instance.new("Tool")
    tool.Name = "TP Tool"
    tool.RequiresHandle = false
    tool.CanBeDropped = false

    local equipped = false
    local mouse = LocalPlayer:GetMouse()

    tool.Equipped:Connect(function() equipped = true end)
    tool.Unequipped:Connect(function() equipped = false end)

    tool.Activated:Connect(function()
        if not equipped then return end
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp and mouse.Target then
            hrp.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0, 3, 0))
        end
    end)

    tool.Parent = LocalPlayer.Backpack
    tpToolInstance = tool
end

local function removeTpTool()
    if tpToolInstance then tpToolInstance:Destroy(); tpToolInstance = nil end
    local char = LocalPlayer.Character
    if char then
        local t = char:FindFirstChild("TP Tool")
        if t then t:Destroy() end
    end
    local t2 = LocalPlayer.Backpack:FindFirstChild("TP Tool")
    if t2 then t2:Destroy() end
end

