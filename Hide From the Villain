        isHoldingPhase = not isHoldingPhase
    elseif input.KeyCode == keybinds.powerInvis and Config.Powers.powerInvis then
        Config.Powers.powerInvis = not Config.Powers.powerInvis
    elseif input.KeyCode == keybinds.powerSpeed and Config.Powers.powerSpeed then
