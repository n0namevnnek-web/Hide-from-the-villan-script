local function addToggle(page, text, tbl, key, color)
    local r = Instance.new("TextButton", page); r.Size=UDim2.new(1,-10,0,40); r.BackgroundColor3=Colors.Card; r.Text=""
    Instance.new("UICorner", r).CornerRadius=UDim.new(0,6)
