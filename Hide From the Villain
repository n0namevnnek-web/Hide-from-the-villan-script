-- Infinite Jump
local ijCharacter, ijHumanoid, ijRootPart, ijTrueJumpPower = nil, nil, nil, 0
local ijCharacterAddedConn, ijHeartbeatConn, ijJumpRequestConn = nil, nil, nil

local function ijCleanupCharacter()
    if ijHeartbeatConn then ijHeartbeatConn:Disconnect(); ijHeartbeatConn = nil end
end

local function ijSetupCharacter(char)
    ijCleanupCharacter()
    ijCharacter = char
    ijHumanoid = char:WaitForChild("Humanoid")
    ijRootPart = char:WaitForChild("HumanoidRootPart")

    if ijHumanoid.UseJumpPower then
        ijTrueJumpPower = ijHumanoid.JumpPower
        ijHumanoid.JumpPower = 0
    else
        ijTrueJumpPower = math.sqrt(2 * workspace.Gravity * ijHumanoid.JumpHeight)
        ijHumanoid.JumpHeight = 0
    end
end

local function toggleInfiniteJump(state)
    if state then
        if LocalPlayer.Character then ijSetupCharacter(LocalPlayer.Character) end
        ijCharacterAddedConn = LocalPlayer.CharacterAdded:Connect(ijSetupCharacter)
        ijJumpRequestConn = UIS.JumpRequest:Connect(function()
            if not ijHumanoid or not ijRootPart then return end
            local v = ijRootPart.AssemblyLinearVelocity
            ijRootPart.AssemblyLinearVelocity = Vector3.new(v.X, ijTrueJumpPower, v.Z)
        end)
    else
        if ijJumpRequestConn then ijJumpRequestConn:Disconnect(); ijJumpRequestConn = nil end
        if ijCharacterAddedConn then ijCharacterAddedConn:Disconnect(); ijCharacterAddedConn = nil end
        if ijHumanoid then
            if ijHumanoid.UseJumpPower then ijHumanoid.JumpPower = ijTrueJumpPower
            else ijHumanoid.JumpHeight = (ijTrueJumpPower * ijTrueJumpPower) / (2 * workspace.Gravity) end
        end
        ijCleanupCharacter()
    end
end

-- Phasing
local phasingConnections = {}
local currentPhaseTime = 5
local isHoldingPhase, isPhasing = false, false
local rootJointOriginalC0 = nil

local function getRootJoint(character)
    if character then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            return rootPart:FindFirstChild("RootJoint") or rootPart:FindFirstChild("RootClip")
        end
    end
    return nil
end

local function resetCollision(character)
    if character then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CanCollide = true end
    end
end

local function togglePhasing(state)
    for _, conn in ipairs(phasingConnections) do conn:Disconnect() end
    phasingConnections = {}

    if not state then
        isHoldingPhase, isPhasing = false, false
        local joint = getRootJoint(LocalPlayer.Character)
        if joint and rootJointOriginalC0 then joint.C0 = rootJointOriginalC0 end
        resetCollision(LocalPlayer.Character)
        return
    end

    table.insert(phasingConnections, RunService.RenderStepped:Connect(function(dt)
        local character = LocalPlayer.Character
        if not character then return end

        local humanoid = character:FindFirstChild("Humanoid")
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if not humanoid or not rootPart then return end

        local maxTime = Config.Powers.phaseDuration

        if isHoldingPhase and (currentPhaseTime > 0 or maxTime == math.huge) then
            isPhasing = true
            if maxTime ~= math.huge then currentPhaseTime = math.max(0, currentPhaseTime - dt) end
        else
            isPhasing = false
            if maxTime ~= math.huge then currentPhaseTime = math.min(maxTime, currentPhaseTime + dt) end
        end

        local joint = getRootJoint(character)
        if not joint then return end
        if not rootJointOriginalC0 then rootJointOriginalC0 = joint.C0 end

        if isPhasing then
            local randomDir = Vector3.new((math.random() - 0.5) * 2, (math.random() - 0.5) * 2, (math.random() - 0.5) * 2)
            if randomDir.Magnitude > 0 then
                randomDir = randomDir.Unit
                local offset = randomDir * (math.random() * 1.5)
                joint.C0 = rootJointOriginalC0 * CFrame.new(offset.X, offset.Y, offset.Z)
            end
        else
            joint.C0 = rootJointOriginalC0
        end
    end))

    table.insert(phasingConnections, RunService.Stepped:Connect(function()
        if isPhasing and LocalPlayer.Character then
            for _, part in ipairs(LocalPlayer.Character:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        elseif not isPhasing and LocalPlayer.Character then
            resetCollision(LocalPlayer.Character)
        end
    end))
end

