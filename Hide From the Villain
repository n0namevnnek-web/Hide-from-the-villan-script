    l.Text=text; l.TextColor3=Colors.Text; l.Font=Enum.Font.GothamMedium; l.TextSize=13; l.TextXAlignment=Enum.TextXAlignment.Left
    local tBg = Instance.new("Frame", r); tBg.Size=UDim2.new(0,36,0,18); tBg.Position=UDim2.new(1,-50,0.5,-9); tBg.BackgroundColor3=Colors.Off
    Instance.new("UICorner", tBg).CornerRadius=UDim.new(1,0)
    local tC = Instance.new("Frame", tBg); tC.Size=UDim2.new(0,14,0,14); tC.Position=UDim2.new(0,2,0,2); tC.BackgroundColor3=Colors.SubText
    Instance.new("UICorner", tC).CornerRadius=UDim.new(1,0)
    local function up()
        local s=tbl[key]
        TweenService:Create(tBg,TweenInfo.new(0.2),{BackgroundColor3=s and (color or Colors.Accent) or Colors.Off}):Play()
        TweenService:Create(tC,TweenInfo.new(0.2),{Position=s and UDim2.new(1,-16,0,2) or UDim2.new(0,2,0,2), BackgroundColor3=s and Colors.Text or Colors.SubText}):Play()
    end; up()
    r.MouseButton1Click:Connect(function() tbl[key]=not tbl[key]; up() end)
end

local function addSlider(page, text, tbl, key, min, max, color)
    local r = Instance.new("Frame", page); r.Size=UDim2.new(1,-10,0,50); r.BackgroundColor3=Colors.Card
    Instance.new("UICorner", r).CornerRadius=UDim.new(0,6)
