-- ===== ESP FUNCTIONS =====
local function getTeamColor(player)
    if not player.Team then return Color3.fromRGB(128, 128, 128) end
    
    local teamName = player.Team.Name
    if teamName == "Villain" then
        return Color3.fromRGB(255, 0, 0)
    elseif teamName == "Survivors" then
        return Color3.fromRGB(0, 255, 0)
    elseif teamName == "Lobby" then
        return Color3.fromRGB(128, 128, 128)
    else
        return Color3.fromRGB(128, 128, 128)
    end
end

local function updateESPVisibility()
    for _, player in Players:GetPlayers() do
        if player ~= LocalPlayer and player.Character then
            local highlight = player.Character:FindFirstChild("ESP_Highlight")
            local head = player.Character:FindFirstChild("Head")
            local billboard = head and head:FindFirstChild("ESP_Name")
            
            if highlight and billboard then
                local teamName = player.Team and player.Team.Name or ""
                local visible = false
                
                if teamName == "Villain" and settings.espVillain then
                    visible = true
                elseif teamName == "Survivors" and settings.espSurvivors then
                    visible = true
                elseif teamName == "Lobby" and settings.espLobby then
                    visible = true
                end
                
                highlight.Enabled = visible
                billboard.Enabled = visible
            end
        end
    end
end

local function createESP(player)
    if player == LocalPlayer then return end
    if not player.Character then return end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = player.Character
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Name"
    billboard.Adornee = player.Character:FindFirstChild("Head")
    billboard.Size = UDim2.new(0, 200, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, 0, 1, 0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextScaled = false
    textLabel.TextSize = 14
    textLabel.Font = Enum.Font.SourceSansLight
    textLabel.TextStrokeTransparency = 0.3
    textLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    textLabel.TextXAlignment = Enum.TextXAlignment.Center
    textLabel.TextYAlignment = Enum.TextYAlignment.Center
    textLabel.Parent = billboard

    highlight.Parent = player.Character
    billboard.Parent = player.Character:FindFirstChild("Head")
    
    return highlight, billboard
end

local function updateESPColor(player)
    if not player.Character then return end
    
    local highlight = player.Character:FindFirstChild("ESP_Highlight")
    local head = player.Character:FindFirstChild("Head")
    local billboard = head and head:FindFirstChild("ESP_Name")
    
    if not highlight or not billboard then return end

    local color = getTeamColor(player)
    local teamName = player.Team and player.Team.Name or "Unknown"
    
    local shortTeam = ""
    if teamName == "Villain" then
        shortTeam = "VL"
    elseif teamName == "Survivors" then
        shortTeam = "SV"
    elseif teamName == "Lobby" then
        shortTeam = "LB"
    else
        shortTeam = "??"
    end

    highlight.FillColor = color
    highlight.OutlineColor = color

    local textLabel = billboard:FindFirstChildOfClass("TextLabel")
    if textLabel then
        textLabel.TextColor3 = color
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = math.floor((player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude)
            textLabel.Text = player.Name .. " [" .. shortTeam .. "] " .. dist .. "m"
        else
            textLabel.Text = player.Name .. " [" .. shortTeam .. "]"
        end
    end
    
    local visible = false
    if teamName == "Villain" and settings.espVillain then
        visible = true
    elseif teamName == "Survivors" and settings.espSurvivors then
        visible = true
    elseif teamName == "Lobby" and settings.espLobby then
        visible = true
    end
    
    highlight.Enabled = visible
    billboard.Enabled = visible
end

local function removeESP(player)
    if player.Character then
        local highlight = player.Character:FindFirstChild("ESP_Highlight")
        if highlight then highlight:Destroy() end

        local head = player.Character:FindFirstChild("Head")
        if head then
            local billboard = head:FindFirstChild("ESP_Name")
            if billboard then billboard:Destroy() end
        end
    end
end

-- ===== AIMBOT =====
local function getAimbotTarget()
    local closestTarget = nil
    local closestDistance = 150
    
    if not LocalPlayer.Character then return nil end
    local rootPart = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    for _, player in Players:GetPlayers() do
        if player == LocalPlayer then continue end
        if not player.Character then continue end
        
        local targetRoot = player.Character:FindFirstChild("HumanoidRootPart")
        local head = player.Character:FindFirstChild("Head")
        if not targetRoot or not head then continue end
        
        local teamName = player.Team and player.Team.Name or ""
        local canAim = false
        
        if teamName == "Villain" and settings.aimbotVillain then
            canAim = true
        elseif teamName == "Survivors" and settings.aimbotSurvivors then
            canAim = true
        end
        
        if not canAim then continue end
        
        local pos, onScreen = Workspace.CurrentCamera:WorldToScreenPoint(head.Position)
        if not onScreen then continue end
        
        local screenCenter = Vector2.new(Workspace.CurrentCamera.ViewportSize.X / 2, Workspace.CurrentCamera.ViewportSize.Y / 2)
        local distance = (Vector2.new(pos.X, pos.Y) - screenCenter).Magnitude
        
        if distance < closestDistance then
            closestDistance = distance
            closestTarget = head
        end
    end
    
    return closestTarget
end

RunService.Heartbeat:Connect(function()
    if not settings.aimbotVillain and not settings.aimbotSurvivors then return end
    if not LocalPlayer.Character then return end
    
    local target = getAimbotTarget()
    if target then
        local camera = Workspace.CurrentCamera
        local targetPos = target.Position
        local currentPos = camera.CFrame.Position
        
        local direction = (targetPos - currentPos).Unit
        local newCFrame = CFrame.lookAt(currentPos, currentPos + direction)
        
        local smoothFactor = settings.aimbotSmoothness
        camera.CFrame = camera.CFrame:Lerp(newCFrame, smoothFactor)
    end
end)

